OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google AI (Gemini). GEMINI_API_KEY or GOOGLE_API_KEY
GEMINI_API_KEY=
# Prefer gemini-2.0-flash if gemini-2.5-flash returns 503 (high demand).
GEMINI_MODEL=gemini-2.0-flash

# Local / offline: OpenAI-compatible HTTP API (Ollama, LM Studio, OpenClaw Gateway, …).
# Ollama: run `ollama serve` then `ollama pull qwen2.5-coder:7b`
# OpenClaw Gateway (:18789): HTTP /v1/chat/completions is off by default — enable it or you get 404/405.
#   openclaw config set gateway.http.endpoints.chatCompletions.enabled true  (then restart gateway)
#   Model: openclaw/default. Bearer token in LOCAL_LLM_API_KEY if gateway uses token auth.
# Ollama (often used by OpenClaw locally): http://127.0.0.1:11434/v1 — model from `ollama list` (e.g. gemma4:latest).
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
LOCAL_LLM_MODEL=qwen2.5-coder:7b
# Ollama: any non-empty value. OpenClaw (token/password auth): gateway bearer token.
LOCAL_LLM_API_KEY=ollama
# Local: max completion tokens (large Terraform JSON needs high values; default 32768).
# LOCAL_LLM_MAX_TOKENS=65536
# Local: try OpenAI json_object mode first (Ollama often supports it). Set to 0 to skip.
# LOCAL_LLM_JSON_MODE=0

# Optional GitHub repo analysis (public repos work without token; token helps rate limits + private repos).
# GITHUB_TOKEN=

# Cap for combined user text + repo snapshot sent to the model (characters).
# ANALYZE_CONTEXT_MAX_CHARS=150000
# REPO_ZIP_MAX_MB=20
# REPO_FILE_MAX_BYTES=96000
# REPO_CONTEXT_MAX_CHARS=95000
# REPO_FETCH_TIMEOUT_MS=45000

PORT=8787
